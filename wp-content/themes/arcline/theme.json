{
	"version": 2,
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"palette": [
				{
					"slug": "base",
					"color": "#ffffff",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#000000",
					"name": "Contrast"
				},
				{
					"slug": "primary",
					"color": "#ffbb00",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#ff0088",
					"name": "Secondary"
				}
			]
		},
		"layout": {
			"contentSize": "900px",
			"wideSize": "1300px"
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ]
		},
		"typography": {
			"fontFamilies": [
				{
					"name": "System (Roboto, Segoe UI, Ubuntu)",
					"slug": "system",
					"fontFamily": "-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Oxygen-Sans,Ubuntu,Cantarell,\"Helvetica Neue\",sans-serif"
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)"
		},
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"blocks": {
			"core/paragraph": {
				"color": {
					"text": "#000000"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "1.1rem",
					"fontWeight": "500",
					"lineHeight": "1.3",
					"letterSpacing": "-0.02em"
				},
				"spacing": {
					"margin": {
						"bottom": "1.5rem"
					}
				}
			},
			"core/heading": {
				"typography": {
					"fontWeight": "900",
					"lineHeight": "0.95",
					"letterSpacing": "-0.05em",
					"textTransform": "uppercase",
					"fontSize": "clamp(2rem, 7vw, 4rem)"
				}
			},
			"core/list": {
				"color": {
					"text": "#000000"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "1.1rem",
					"fontWeight": "500",
					"lineHeight": "1.5",
					"letterSpacing": "-0.02em"
				},
				"spacing": {
					"margin": { "bottom": "1.5rem" },
					"padding": { "left": "1.2rem" }
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "clamp(3rem, 7vw, 6rem)",
					"fontWeight": "900",
					"fontStyle": "italic",
					"lineHeight": "0.8",
					"letterSpacing": "-0.06em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "#000000"
				},
				"spacing": {
					"margin": {
						"top": "4rem",
						"bottom": "4rem"
					},
					"padding": {
						"left": "0px"
					}
				}
			},
			"core/code": {
				"border": {
					"color": "#000000",
					"style": "solid",
					"width": "4px"
				},
				"color": {
					"text": "#000000",
					"background": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontFamily": "monospace",
					"fontSize": "1.1rem",
					"fontWeight": "700",
					"lineHeight": "1.4"
				},
				"spacing": {
					"padding": {
						"top": "2rem",
						"bottom": "2rem",
						"left": "2rem",
						"right": "2rem"
					},
					"margin": {
						"bottom": "3rem",
						"top": "2rem"
					}
				}
			},
			"core/details": {
				"border": {
					"color": "#000000",
					"style": "solid",
					"width": "3px"
				},
				"color": {
					"text": "#000000",
					"background": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "1.75rem",
					"fontWeight": "900",
					"lineHeight": "0.9",
					"letterSpacing": "-0.06em",
					"textTransform": "uppercase"
				},
				"spacing": {
					"padding": {
						"top": "1.25rem",
						"bottom": "1.25rem",
						"left": "1.5rem",
						"right": "1.5rem"
					},
					"margin": {
						"bottom": "1.5rem"
					}
				}
			},
			"core/math": {
				"color": {
					"text": "#000000"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "1.1rem",
					"fontWeight": "500",
					"lineHeight": "1.4",
					"letterSpacing": "-0.02em"
				},
				"spacing": {
					"margin": {
						"bottom": "1.5rem"
					}
				}
			},
			"core/preformatted": {
				"border": {
					"left": {
						"color": "#000000",
						"style": "solid",
						"width": "20px"
					},
					"bottom": {
						"color": "var(--wp--preset--color--secondary)",
						"style": "solid",
						"width": "10px"
					},
					"right": {
						"color": "#000000",
						"style": "solid",
						"width": "1px"
					},
					"top": {
						"color": "#000000",
						"style": "solid",
						"width": "1px"
					}
				},
				"color": {
					"text": "#000000",
					"background": "#ffffff"
				},
				"typography": {
					"fontFamily": "monospace",
					"fontSize": "1.2rem",
					"fontWeight": "800",
					"lineHeight": "1.1",
					"letterSpacing": "-0.05em"
				},
				"spacing": {
					"padding": {
						"top": "2rem",
						"bottom": "2rem",
						"left": "2.5rem",
						"right": "2rem"
					},
					"margin": {
						"bottom": "4rem",
						"left": "0"
					}
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "clamp(3.5rem, 9vw, 7.5rem)",
					"fontWeight": "900",
					"fontStyle": "italic",
					"lineHeight": "0.75",
					"letterSpacing": "-0.08em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "#000000"
				},
				"spacing": {
					"margin": {
						"top": "0.5rem",
						"bottom": "0.5rem"
					},
					"padding": {
						"top": "0px",
						"bottom": "0px",
						"left": "0px"
					}
				},
				"border": {
					"width": "0px",
					"style": "none"
				}
			},
			"core/table": {
				"border": {
					"color": "#000000",
					"style": "solid",
					"width": "2px"
				},
				"color": {
					"text": "#000000",
					"background": "#ffffff"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "1.1rem",
					"fontWeight": "500",
					"lineHeight": "1.4",
					"letterSpacing": "-0.02em"
				},
				"spacing": {
					"padding": {
						"top": "1rem",
						"bottom": "1rem",
						"left": "1rem",
						"right": "1rem"
					},
					"margin": {
						"bottom": "2rem"
					}
				}
			},
			"core/verse": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "1.1rem",
					"fontWeight": "500",
					"lineHeight": "1.4",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "#000000"
				},
				"spacing": {
					"margin": {
						"bottom": "1.5rem"
					}
				}
			},
			"core/classic": {
				"color": {
					"text": "#000000"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-font)",
					"fontSize": "1.1rem",
					"fontWeight": "500",
					"lineHeight": "1.4",
					"letterSpacing": "-0.02em"
				},
				"spacing": {
					"margin": {
						"bottom": "1.5rem"
					}
				}
			}
		}
	}
}
